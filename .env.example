# RPC URLs
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
# Generic RPC URL (optional, can override specific network URLs)
RPC_URL=

# Private Keys (Industry Standard: Use Hardhat Vars or Secret Managers for Production)
# DO NOT COMMIT ACTUAL PRIVATE KEYS TO VERSION CONTROL
SEPOLIA_PRIVATE_KEY=
MAINNET_PRIVATE_KEY=
# Private key for the buyer in seeding scripts
SEPOLIA_BUYER_PRIVATE_KEY=

# API Keys
ALCHEMY_API_KEY=
# Required for gasless deployments on Sepolia
ALCHEMY_GAS_POLICY_ID=
# Gemini API Key for AI NFT generation ( Imagen 4.0 )
GEMINI_API_KEY=
# Alternative to GEMINI_API_KEY
GOOGLE_API_KEY=

# Optional Configuration
# Address of an existing Treasury contract to use instead of deploying a new one
TREASURY_ADDRESS=
# URL for the Minecraft Bedrock Server Manager API
MANAGER_API_URL=http://localhost:9003
# Chain ID for the network (default: 31337 for localhost)
CHAIN_ID=31337

# --- Environment Management ---
# Set to 'staging' to use staging services instead of local ones
APP_ENV=local
# Unique ID for this Minecraft server instance (default: local-dev)
SERVER_ID=local-dev

# --- Staging Configuration (Required if APP_ENV=staging) ---
# Live Bridge URL (WebSocket) for the addon to connect to
STAGING_BRIDGE_URL=
# Live Manager API URL for the environment manager to talk to
STAGING_MANAGER_URL=
# Live BragNFT contract address for the addon info command
STAGING_BRAGNFT_ADDRESS=
